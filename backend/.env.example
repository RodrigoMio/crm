# Copie para .env e preencha (nunca commite .env).
# Rodar o backend a partir da pasta backend: npm run start:dev

NODE_ENV=development

# --- Opção A (recomendada no Railway): uma URL só ---
# No PC local, use a URL *pública* do Postgres no Railway (DATABASE_PUBLIC_URL),
# pois postgres.railway.internal só funciona *dentro* da rede Railway.
# Ex.: postgresql://postgres:SENHA@xxxx.proxy.rlwy.net:PORTA/railway
# Sem aspas nem espaços no início/fim. Se aparecer getaddrinfo EAI_FAIL, o PC não resolve o host (DNS/rede):
# no PowerShell: nslookup <host_do_proxy>.rlwy.net
DATABASE_URL=

# --- Opção B: variáveis separadas (se não usar DATABASE_URL) ---
# DB_HOST=
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_DATABASE=railway
# DB_SSL=true

# Fuso da sessão PostgreSQL (definir também no serviço Node no Railway)
DB_TIMEZONE=America/Sao_Paulo

# JWT e front (ajuste conforme seu projeto)
JWT_SECRET=troque-em-producao
JWT_EXPIRES_IN=7d

# Opcional: URL(s) do front para CORS (main.ts)
# FRONTEND_URL=http://localhost:5173

# Opcional: build do front servido pelo Nest em produção
# FRONTEND_DIST_PATH=

# SSL forçado (opcional se DATABASE_URL já for *.rlwy.net com TLS)
# DB_SSL=true
